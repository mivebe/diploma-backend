PORT=4000
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=24h

# Локална SQLite база (използва се ако TURSO_DATABASE_URL не е зададено)
DB_PATH=./data/app.db

# Turso (хоствана SQLite база) — задайте за продукция
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=eyJ...
